TAVILY_API_KEY=tvly-dev-...

# GitHub account that owns the persistent browser profile (the repo owner).
# Surfaced to the Planner/Publisher as a GITHUB IDENTITY block so generated
# github.com/<username>/<repo> URLs target the right account. Should match the
# logged-in user verified by `uv run python github_auth.py`. May instead live in
# the repo-root .env (loaded first); a value there wins over this file.
GITHUB_USERNAME=your-github-username
